{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/check_asset_size.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Before ending: did any good ideas come up that belong in planning/claude_suggestions.md?'"
          }
        ]
      }
    ]
  }
}
